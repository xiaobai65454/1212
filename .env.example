# ============================================
# 小白白智能体 - 环境变量配置
# ============================================

# LLM 配置（豆包 API）
# 获取 API Key: https://console.volcengine.com/ark/region:ark+apiKey
# 注意：API Key 格式为 ark-xxxxx，请确保完整复制
DOUBAO_API_KEY=ark-your-api-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-lite-32k-250115

# 也可以使用 LLM_API_KEY（兼容旧配置）
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=doubao-seed-2-0-lite-260215

# 知识库数据目录（可选，默认 ./data/knowledge）
# Docker 部署时建议设置为 /app/data/knowledge
# KNOWLEDGE_BASE_PATH=./data/knowledge

# 管理后台登录密码
ADMIN_PASSWORD=xiaobaibai2024
